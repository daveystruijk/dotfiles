{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#363646",
          "foreground": "#7E9CD8",
          "style": "powerline",
          "template": "  ",
          "type": "os"
        },
        {
          "background": "#2A2A37",
          "foreground": "#DCD7BA",
          "powerline_symbol": "",
          "style": "powerline",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3
          },
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#223249",
          "foreground": "#76946A",
          "foreground_templates": [
            "{{ if .Working.Changed }}#DCA561{{ end }}",
            "{{ if and (.Staging.Changed) (not .Working.Changed) }}#98BB6C{{ end }}"
          ],
          "powerline_symbol": "",
          "style": "powerline",
          "properties": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} <#DCA561> {{ .Working.String }}</>{{ end }}{{ if .Staging.Changed }} <#98BB6C> {{ .Staging.String }}</>{{ end }} ",
          "type": "git"
        },
        {
          "background": "#2B3328",
          "foreground": "#98BB6C",
          "powerline_symbol": "",
          "style": "powerline",
          "properties": {
            "fetch_version": true
          },
          "template": "  {{ .Full }} ",
          "type": "node"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#E6C384",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#C34043{{ end }}"
          ],
          "style": "plain",
          "template": "❯",
          "type": "exit"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 3
}
