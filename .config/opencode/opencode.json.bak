{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "disable_paste_summary": true
  },
  "plugin": [
    "@ex-machina/opencode-anthropic-auth",
    "@mohak34/opencode-notifier@latest",
    "oh-my-opencode-slim"
  ],
  "permission": {
    "external_directory": {
      "~/momo/**": "allow"
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}
