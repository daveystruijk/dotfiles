{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "disable_paste_summary": true
  },
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.8.0",
    "@mohak34/opencode-notifier@0.2.8",
    "opencode-history-search@1.4.1",
    "oh-my-opencode-slim"
  ],
  "permission": {
    "external_directory": {
      "~/momo/**": "allow",
      "~/decisions/**": "allow",
      "~/.cargo/**": "allow"
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  },
  "lsp": true
}
