{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "disable_paste_summary": true
  },
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@latest",
    "@mohak34/opencode-notifier@latest",
    "oh-my-opencode-slim",
    "opencode-browser"
  ],
  "permission": {
    "external_directory": {
      "~/momo/**": "allow",
      "~/.cargo/**": "allow",
      "~/screenshots/**": "allow"
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "mcp": {
    "browsermcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@browsermcp/mcp@0.1.3"
      ],
      "enabled": true
    }
  }
}
