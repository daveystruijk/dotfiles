{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "disable_paste_summary": true
  },
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.8.0",
    "@mohak34/opencode-notifier@latest",
    "oh-my-opencode-slim",
    "opencode-cmux"
  ],
  "permission": {
    "external_directory": {
      "~/momo/**": "allow",
      "~/.cargo/**": "allow"
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}
